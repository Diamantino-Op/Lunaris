{
  "name": "Lunaris Lua Injection",
  "scopeName": "lunaris.lua.injection",
  "injectionSelector": "L:source.lua",
  "patterns": [
    {
      "name": "keyword.control.lunaris",
      "match": "(?m)^\\s*data\\b"
    },
    {
      "name": "storage.modifier.lunaris",
      "match": "(?<![A-Za-z0-9_])section(?=\\s+\")"
    },
    {
      "name": "storage.type.lunaris",
      "match": "(?m)^\\s*packed\\s+struct\\b"
    },
    {
      "name": "keyword.declaration.lunaris",
      "match": "(?m)^\\s*struct\\b"
    },
    {
      "name": "keyword.control.lunaris",
      "match": "(?m)^\\s*asm\\s+function\\b"
    },
    {
      "name": "keyword.operator.comparison.lunaris",
      "match": "(?<![A-Za-z0-9_])~=(?![A-Za-z0-9_])"
    },
    {
      "name": "entity.name.type.lunaris",
      "match": "(?<=:\\s*)([A-Za-z_][A-Za-z0-9_]*(?:\\([^\\n]*\\))*)"
    },
    {
      "name": "entity.name.type.lunaris",
      "match": "(?<=\\bdata\\s+[A-Za-z_][A-Za-z0-9_]*\\s*:\\s*)([A-Za-z_][A-Za-z0-9_]*(?:\\([^\\n]*\\))*)"
    },
    {
      "name": "entity.name.type.lunaris",
      "match": "(?<=\\bfunction\\s+[A-Za-z_][A-Za-z0-9_]*\\s*\\([^)]*:\\s*)([A-Za-z_][A-Za-z0-9_]*(?:\\([^\\n]*\\))*)"
    }
  ]
}